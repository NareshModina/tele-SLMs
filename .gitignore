# Ignore everything by default
*

# ── Allow Python source files ─────────────────────────────────────────────
!*.py
!*.md
!*.txt
!*.yaml
!*.yml
!SmolLM-TS-135M
SmolLM-TS-135M-it-modelcard.md
SmolLM-TS-135M-modelcard.md
# ── Allow results directory ───────────────────────────────────────────────
!results/
!results/**
# ── Always block large/generated dirs ────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/

# ── macOS ─────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ── Environments ──────────────────────────────────────────────────────────
.env
.venv/
venv/
*.env

# ── Jupyter ───────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Editors ───────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Large training artifacts ──────────────────────────────────────────────
checkpoints/
logs/
tele-tokenized*/